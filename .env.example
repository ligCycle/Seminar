# คัดลอกไฟล์นี้เป็น .env แล้วแก้ค่าตามจริง

# PostgreSQL — บน Railway จะถูกตั้งให้อัตโนมัติเมื่อเพิ่ม PostgreSQL plugin
# สำหรับ local ตัวอย่าง: postgresql://postgres:password@localhost:5432/seminar
DATABASE_URL=postgresql://postgres:password@localhost:5432/seminar

# รหัสผ่านสำหรับเข้าหน้า Admin (เปลี่ยนก่อน deploy จริง!)
ADMIN_PASSWORD=change-me-please

# secret สำหรับเซ็น session token (ตั้งเป็นสตริงสุ่มยาวๆ) — ถ้าไม่ตั้ง ระบบจะสุ่มให้ตอน start
TOKEN_SECRET=

# พอร์ต (Railway ตั้งให้อัตโนมัติ ไม่ต้องแก้)
PORT=3000

# ถ้า Postgres local ไม่ใช้ SSL ปล่อยว่างไว้; ตั้ง true เพื่อบังคับ SSL
PGSSL=

# ---------- อีเมล (ระบบส่งถามการมา RSVP) ----------
# แนะนำ: Brevo (ส่งผ่าน HTTPS ทำงานได้บน Railway) — สมัครที่ brevo.com, ยืนยันอีเมลผู้ส่ง, สร้าง API key
BREVO_API_KEY=
BREVO_SENDER=youremail@example.com

# ทางเลือก: Gmail SMTP (มักถูกบล็อกบน Railway) — เปิด 2FA แล้วสร้าง App Password ที่ myaccount.google.com/apppasswords
GMAIL_USER=
GMAIL_APP_PASSWORD=

# ตั้ง true เพื่อ "ไม่ส่งจริง" (log อย่างเดียว) — ใช้ตอนทดสอบ; ปล่อยว่าง/false เพื่อส่งจริง
MAIL_DRYRUN=

# ---------- SMS OTP ยืนยันเบอร์ (Twilio) ----------
# ถ้าไม่ตั้งค่า = dev-mode (โชว์ OTP บนจอ/log ไม่ส่ง SMS จริง)
# ตั้งครบ 3 ค่า = ส่ง SMS จริงผ่าน Twilio (trial ส่งได้เฉพาะเบอร์ที่ verify ใน Twilio)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
